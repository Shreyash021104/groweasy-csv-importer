# Server
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Which AI provider to use: openai | gemini | anthropic | groq | heuristic
# "heuristic" is a rule-based fallback (no API key needed) so the app still
# works end-to-end without any AI credentials.
AI_PROVIDER=heuristic

# Only the key matching AI_PROVIDER is required.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Groq (OpenAI-compatible API, fast open-model inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Rows sent to the AI per batch
AI_BATCH_SIZE=25
# Max concurrent batch calls in flight
AI_BATCH_CONCURRENCY=3
# Retries per batch on failure
AI_BATCH_RETRIES=2

# Max upload size in bytes (5MB default)
MAX_UPLOAD_BYTES=5242880
